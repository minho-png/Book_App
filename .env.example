# ── Root-level environment variables ────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Railway DB Connect 탭에서 확인 (예: postgresql://postgres:pw@host:port/db)
# 백엔드 서비스에서 자동으로 postgresql+asyncpg://로 변환됨
POSTGRES_URL=postgresql://postgres:password@postgres-production-f9c1.up.railway.app:5432/railway

# ── Google Gemini ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_MODEL_NAME=gemini-2.0-flash

# ── Backend ───────────────────────────────────────────────────────────────────
# BACKEND_CORS_ORIGINS=["https://${{frontend.RAILWAY_PUBLIC_DOMAIN}}"]
BACKEND_CORS_ORIGINS=["*"]
CRAWL_DELAY_SECONDS=2
CRAWL_INTERVAL_HOURS=6
APP_ENV=production
DEBUG=false

# ── Service URLs (Gateway 설정용) ─────────────────────────────────────────────
# Railway 참조 변수 사용 권장
BOOK_SERVICE_URL=http://${{book-service.RAILWAY_PRIVATE_DOMAIN}}:8001
CRAWL_SERVICE_URL=http://${{crawl-service.RAILWAY_PRIVATE_DOMAIN}}:8002
RECOMMEND_SERVICE_URL=http://${{recommend-service.RAILWAY_PRIVATE_DOMAIN}}:8003

# ── Frontend ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://${{gateway.RAILWAY_PUBLIC_DOMAIN}}
NEXT_PUBLIC_API_URL=http://localhost:80
